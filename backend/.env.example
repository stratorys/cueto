# Backend configuration. Copy to .env; real environment variables override these.

# Directory holding the hand-owned schema.cue and the seed data.cue (read-only).
CUE_DIR=../cue
# Required. Root of the project registry and per-project versions; must be OUTSIDE
# CUE_DIR so stored files never overwrite the seed data.cue or join `package main`.
DATA_DIR=../data
PORT=8091

# Untrusted-input hardening bounds.
MAX_BODY_BYTES=1048576   # request body cap (1 MiB)
MAX_OUTPUT_BYTES=4194304 # evaluated JSON cap (4 MiB)
EVAL_TIMEOUT_MS=2000     # per-request evaluation deadline
MAX_CONCURRENT=4         # concurrent evaluations before 429
